<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DesktopApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DesktopApp">

    <Grid Background="#0F0F13">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TITLEBAR -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
        Background="#13131A"
        BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
            <Grid Padding="16,0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
                    <TextBlock Text="DesktopApp" FontSize="14" FontWeight="SemiBold"
                       Foreground="#A78BFA" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Drag region -->
                <Border Grid.Column="1" Background="Transparent" x:Name="DragRegion"/>

                <!-- Right controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="0">

                    <!-- Pin toggle -->
                    <ToggleButton x:Name="PinToggle"
              IsChecked="True"
              Checked="PinToggle_Checked"
              Unchecked="PinToggle_Unchecked"
              Width="64" Height="32"
              CornerRadius="6"
              Margin="0,0,8,0"
              Padding="0"
              Background="#A78BFA"
              BorderThickness="0">
                        <TextBlock Text="Pin" FontSize="12"
               FontWeight="SemiBold"
               Foreground="White"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Minimize -->
                    <Button x:Name="MinimizeBtn"
        Click="MinimizeBtn_Click"
        Width="32" Height="32"
        CornerRadius="6"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        VerticalAlignment="Center">
                        <TextBlock Text="&#xE921;" 
               FontFamily="Segoe Fluent Icons"
               FontSize="12"
               Foreground="#A78BFA"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Maximize -->
                    <Button x:Name="MaximizeBtn"
        Click="MaximizeBtn_Click"
        Width="32" Height="32"
        CornerRadius="6"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        VerticalAlignment="Center">
                        <TextBlock Text="&#xE922;" 
               FontFamily="Segoe Fluent Icons"
               FontSize="12"
               Foreground="#A78BFA"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Close -->
                    <Button x:Name="CloseBtn"
        Click="CloseBtn_Click"
        Width="32" Height="32"
        CornerRadius="6"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        VerticalAlignment="Center">
                        <TextBlock Text="&#xE8BB;" 
               FontFamily="Segoe Fluent Icons"
               FontSize="12"
               Foreground="#A78BFA"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#1A1A24"
                BorderBrush="#2A2A3A" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PROJECTS"
                           Foreground="#6B7280" FontSize="10" FontWeight="SemiBold"
                           Margin="16,16,16,8" CharacterSpacing="150"/>

                <ListView Grid.Row="1"
                          x:Name="ProjectList"
                          SelectionChanged="ProjectList_SelectionChanged"
                          DragItemsCompleted="ProjectList_DragItemsCompleted"
                          Background="Transparent"
                          SelectionMode="Single"
                          CanReorderItems="True"
                          CanDragItems="True"
                          AllowDrop="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="6,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="4" Height="20" CornerRadius="2"
                                        Background="{Binding Color}"/>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#E2E8F0" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2"
                        Content="+ New Project"
                        Click="AddProject_Click"
                        HorizontalAlignment="Stretch"
                        Margin="12,8,12,16"
                        Background="#252535"
                        Foreground="#A78BFA"
                        CornerRadius="8"
                        Padding="12,8"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <Border Grid.Row="0" Background="#13131A"
        BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
        Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tabs -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <Button x:Name="TabLinks" Content="Links"
                    Click="Tab_Click" Tag="Links"
                    Background="#2D2D3F" Foreground="#E2E8F0"
                    CornerRadius="8" Padding="14,8" Margin="0,6"/>
                        <Button x:Name="TabNotes" Content="Notes"
                    Click="Tab_Click" Tag="Notes"
                    Background="Transparent" Foreground="#6B7280"
                    CornerRadius="8" Padding="14,8" Margin="0,6"/>
                        <Button x:Name="TabTasks" Content="Tasks"
                    Click="Tab_Click" Tag="Tasks"
                    Background="Transparent" Foreground="#6B7280"
                    CornerRadius="8" Padding="14,8" Margin="0,6"/>
                        <Button x:Name="TabFiles" Content="Files"
                     Click="Tab_Click" Tag="Files"
                     Background="Transparent" Foreground="#6B7280"
                     CornerRadius="8" Padding="14,8" Margin="0,6"/>
                        <Button x:Name="TabSettings" Content="Settings"
                    Click="Tab_Click" Tag="Settings"
                    Background="Transparent" Foreground="#6B7280"
                    CornerRadius="8" Padding="14,8" Margin="0,6"/>
                    </StackPanel>

                    <!-- Search -->
                    <AutoSuggestBox Grid.Column="1"
                        x:Name="SearchBox"
                        PlaceholderText="Search notes and tasks..."
                        Width="220"
                        VerticalAlignment="Center"
                        Margin="0,6"
                        TextChanged="SearchBox_TextChanged"
                        SuggestionChosen="SearchBox_SuggestionChosen"/>
                </Grid>
            </Border>

            <!-- Content frame -->
            <Frame Grid.Row="1" x:Name="ContentFrame" Background="#0F0F13"/>
        </Grid>
    </Grid>
</Window>