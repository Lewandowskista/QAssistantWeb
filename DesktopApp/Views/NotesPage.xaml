<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DesktopApp.Views.NotesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DesktopApp.Models"
    Background="#0F0F13">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Notes Sidebar ── -->
        <Border Grid.Column="0" Background="#1A1A24"
                BorderBrush="#2A2A3A" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="NOTES"
                           Foreground="#6B7280" FontSize="10" FontWeight="SemiBold"
                           Margin="16,16,16,8" CharacterSpacing="150"/>
                <ListView Grid.Row="1" x:Name="NotesList"
                          Background="Transparent" SelectionMode="Single"
                          SelectionChanged="NotesList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="6,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Note">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{x:Bind Title}"
                                           Foreground="#E2E8F0" FontSize="13"/>
                                <TextBlock Text="{x:Bind UpdatedAt}"
                                           Foreground="#6B7280" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button Grid.Row="2" Content="+ New Note"
                        Click="AddNote_Click"
                        HorizontalAlignment="Stretch"
                        Margin="12,8,12,16"
                        Background="#252535"
                        Foreground="#A78BFA"
                        CornerRadius="8"
                        Padding="12,8"/>
            </Grid>
        </Border>

        <!-- ── Editor ── -->
        <Grid Grid.Column="1">
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="Select a note or create a new one"
                           Foreground="#6B7280" FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid x:Name="EditorPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBox Grid.Row="0"
                         x:Name="NoteTitleBox"
                         PlaceholderText="Note title..."
                         FontSize="20" FontWeight="SemiBold"
                         Background="Transparent"
                         BorderThickness="0,0,0,1"
                         BorderBrush="#2A2A3A"
                         Foreground="#E2E8F0"
                         Padding="20,16"
                         TextChanged="NoteTitle_Changed"/>

                <!-- Content -->
                <TextBox Grid.Row="1"
                         x:Name="NoteContentBox"
                         PlaceholderText="Write your note here..."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E2E8F0"
                         Padding="20,16"
                         FontSize="14"
                         VerticalAlignment="Stretch"
                         TextChanged="NoteContent_Changed"/>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#13131A"
                        BorderBrush="#2A2A3A" BorderThickness="0,1,0,0"
                        Padding="20,10">
                    <Grid>
                        <TextBlock x:Name="LastSavedText"
                                   Foreground="#6B7280" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button Content="Delete Note"
                                Click="DeleteNote_Click"
                                HorizontalAlignment="Right"
                                Background="#3F1A1A"
                                Foreground="#F87171"
                                CornerRadius="6"
                                Padding="12,6"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>