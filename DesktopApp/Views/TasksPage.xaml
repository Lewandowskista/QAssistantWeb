<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DesktopApp.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DesktopApp.Models"
    Background="#0F0F13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Top bar ── -->
        <Border Grid.Row="0" Background="#13131A"
                BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <TextBlock Text="TASKS" Foreground="#6B7280"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="150" VerticalAlignment="Center"/>
                <Button Content="+ New Task"
                        Click="AddTask_Click"
                        HorizontalAlignment="Right"
                        Background="#252535"
                        Foreground="#A78BFA"
                        CornerRadius="8"
                        Padding="12,6"/>
            </Grid>
        </Border>

        <!-- ── Kanban Board ── -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="12" Padding="16">

                <!-- Todo -->
                <Border Width="240" Background="#1A1A24"
                        CornerRadius="12" Padding="12"
                        BorderBrush="#2A2A3A" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#6B7280"/>
                            <TextBlock Text="TODO" Foreground="#6B7280"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="150"/>
                        </StackPanel>
                        <ListView x:Name="TodoList" Background="Transparent"
                                  SelectionMode="None" ItemClick="Task_Click"
                                  IsItemClickEnabled="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProjectTask">
                                    <Border Background="#252535" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Foreground="#E2E8F0" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Priority}"
                                                       Foreground="#F59E0B" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- In Progress -->
                <Border Width="240" Background="#1A1A24"
                        CornerRadius="12" Padding="12"
                        BorderBrush="#2A2A3A" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#3B82F6"/>
                            <TextBlock Text="IN PROGRESS" Foreground="#3B82F6"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="150"/>
                        </StackPanel>
                        <ListView x:Name="InProgressList" Background="Transparent"
                                  SelectionMode="None" ItemClick="Task_Click"
                                  IsItemClickEnabled="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProjectTask">
                                    <Border Background="#252535" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Foreground="#E2E8F0" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Priority}"
                                                       Foreground="#F59E0B" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- In Review -->
                <Border Width="240" Background="#1A1A24"
                        CornerRadius="12" Padding="12"
                        BorderBrush="#2A2A3A" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#A78BFA"/>
                            <TextBlock Text="IN REVIEW" Foreground="#A78BFA"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="150"/>
                        </StackPanel>
                        <ListView x:Name="InReviewList" Background="Transparent"
                                  SelectionMode="None" ItemClick="Task_Click"
                                  IsItemClickEnabled="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProjectTask">
                                    <Border Background="#252535" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Foreground="#E2E8F0" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Priority}"
                                                       Foreground="#F59E0B" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Done -->
                <Border Width="240" Background="#1A1A24"
                        CornerRadius="12" Padding="12"
                        BorderBrush="#2A2A3A" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#10B981"/>
                            <TextBlock Text="DONE" Foreground="#10B981"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="150"/>
                        </StackPanel>
                        <ListView x:Name="DoneList" Background="Transparent"
                                  SelectionMode="None" ItemClick="Task_Click"
                                  IsItemClickEnabled="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProjectTask">
                                    <Border Background="#252535" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Foreground="#E2E8F0" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Priority}"
                                                       Foreground="#F59E0B" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Blocked -->
                <Border Width="240" Background="#1A1A24"
                        CornerRadius="12" Padding="12"
                        BorderBrush="#2A2A3A" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                            <TextBlock Text="BLOCKED" Foreground="#EF4444"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="150"/>
                        </StackPanel>
                        <ListView x:Name="BlockedList" Background="Transparent"
                                  SelectionMode="None" ItemClick="Task_Click"
                                  IsItemClickEnabled="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProjectTask">
                                    <Border Background="#252535" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Foreground="#E2E8F0" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Priority}"
                                                       Foreground="#F59E0B" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>