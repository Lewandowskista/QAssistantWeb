<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DesktopApp.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F0F13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#13131A"
                BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="ManualModeBtn" Content="Manual" Click="ManualMode_Click"
                            Background="#A78BFA" Foreground="White"
                            CornerRadius="6" Padding="12,6"/>
                    <Button x:Name="LinearModeBtn" Content="Linear" Click="LinearMode_Click"
                            Background="Transparent" Foreground="#6B7280"
                            CornerRadius="6" Padding="12,6"/>
                    <Button x:Name="RefreshBtn" Content="Refresh" Click="Refresh_Click"
                            Visibility="Collapsed"
                            Background="#252535" Foreground="#6B7280"
                            CornerRadius="8" Padding="12,6"/>
                    <TextBlock x:Name="StatusText" Foreground="#6B7280"
                               FontSize="12" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
                <Button x:Name="AddTaskBtn" Content="+ New Task" Click="AddTask_Click"
                        HorizontalAlignment="Right"
                        Background="#252535" Foreground="#A78BFA"
                        CornerRadius="8" Padding="12,6"/>
            </Grid>
        </Border>

        <!-- Main Content: Kanban + Detail Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="DetailPanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Kanban Board -->
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="12" Padding="16">

                    <!-- TODO -->
                    <Border Width="240" Background="#1A1A24" CornerRadius="12"
                            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="TODO" Foreground="#6B7280"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="#252535" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="TodoCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="TodoList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#252535" CornerRadius="8"
                                                Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- IN PROGRESS -->
                    <Border Width="240" Background="#1A1A24" CornerRadius="12"
                            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="IN PROGRESS" Foreground="#3B82F6"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="#252535" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="InProgressCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="InProgressList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#252535" CornerRadius="8"
                                                Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- IN REVIEW -->
                    <Border Width="240" Background="#1A1A24" CornerRadius="12"
                            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="IN REVIEW" Foreground="#A78BFA"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="#252535" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="InReviewCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="InReviewList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#252535" CornerRadius="8"
                                                Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- DONE -->
                    <Border Width="240" Background="#1A1A24" CornerRadius="12"
                            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="DONE" Foreground="#10B981"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="#252535" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="DoneCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="DoneList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#252535" CornerRadius="8"
                                                Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- BLOCKED -->
                    <Border Width="240" Background="#1A1A24" CornerRadius="12"
                            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="BLOCKED" Foreground="#EF4444"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="#252535" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="BlockedCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="BlockedList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#252535" CornerRadius="8"
                                                Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="#13131A"
                    BorderBrush="#2A2A3A" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20,16"
                            BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DetailIdentifier"
                                           Foreground="#6B7280" FontSize="11"/>
                                <TextBlock x:Name="DetailTitle"
                                           Foreground="#E2E8F0" FontSize="16"
                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                    <Border x:Name="DetailStatusBadge" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="DetailStatus" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="8,3" Background="#2D2010">
                                        <TextBlock x:Name="DetailPriority" Foreground="#F59E0B" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Button Content="✕" Click="CloseDetail_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#6B7280" Padding="8,4" FontSize="14"/>
                        </Grid>
                    </Border>

                    <!-- Tab Bar -->
                    <Border Grid.Row="1" Background="#0F0F13"
                            BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button x:Name="TabDetails" Content="Details"
                                    Click="TabDetails_Click"
                                    Background="#1A1A24" Foreground="#A78BFA"
                                    BorderThickness="0,0,0,2" BorderBrush="#A78BFA"
                                    CornerRadius="0" Padding="16,10" FontSize="12"/>
                            <Button x:Name="TabDescription" Content="Description"
                                    Click="TabDescription_Click"
                                    Background="Transparent" Foreground="#6B7280"
                                    BorderThickness="0" CornerRadius="0"
                                    Padding="16,10" FontSize="12"/>
                            <Button x:Name="TabComments" Content="Comments"
                                    Click="TabComments_Click"
                                    Background="Transparent" Foreground="#6B7280"
                                    BorderThickness="0" CornerRadius="0"
                                    Padding="16,10" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab Content -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>

                            <!-- Details Tab -->
                            <StackPanel x:Name="DetailsTab" Spacing="16" Padding="20,16">
                                <StackPanel Spacing="8">
                                    <StackPanel x:Name="DetailAssigneePanel" Orientation="Horizontal"
                                                Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Assignee" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="DetailAssignee" Foreground="#E2E8F0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailDueDatePanel" Orientation="Horizontal"
                                                Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Due Date" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="DetailDueDate" Foreground="#E2E8F0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailLabelsPanel" Orientation="Horizontal"
                                                Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Labels" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="DetailLabels" Foreground="#A78BFA" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                                            
                             <!-- Linear task info -->
                                <StackPanel x:Name="LinearTaskInfo" Spacing="12" Visibility="Collapsed">
                                    <Border Height="1" Background="#2A2A3A"/>
                                    <TextBlock Text="ISSUE DETAILS" Foreground="#6B7280"
                                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Source" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock Text="Linear" Foreground="#E2E8F0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Identifier" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="LinearDetailIdentifier" Foreground="#E2E8F0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Status" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="LinearDetailStatus" Foreground="#E2E8F0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Priority" Foreground="#6B7280" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="LinearDetailPriority" Foreground="#F59E0B" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Manual task fields -->
                                <StackPanel x:Name="ManualTaskFields" Spacing="12" Visibility="Collapsed">
                                    <Border Height="1" Background="#2A2A3A"/>
                                    <TextBlock Text="EDIT TASK" Foreground="#6B7280"
                                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Status" Foreground="#9CA3AF" FontSize="12"/>
                                        <ComboBox x:Name="DetailStatusPicker"
                                                  HorizontalAlignment="Stretch"
                                                  Background="#0F0F13"
                                                  Foreground="#E2E8F0"
                                                  BorderBrush="#2A2A3A"/>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Priority" Foreground="#9CA3AF" FontSize="12"/>
                                        <ComboBox x:Name="DetailPriorityPicker"
                                                  HorizontalAlignment="Stretch"
                                                  Background="#0F0F13"
                                                  Foreground="#E2E8F0"
                                                  BorderBrush="#2A2A3A"/>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <CheckBox x:Name="DetailSetDueDate" Content="Set due date"
                                                  Foreground="#E2E8F0"
                                                  Checked="DetailSetDueDate_Checked"
                                                  Unchecked="DetailSetDueDate_Unchecked"/>
                                        <DatePicker x:Name="DetailDueDatePicker"
                                                    HorizontalAlignment="Stretch"
                                                    Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Description Tab -->
                            <StackPanel x:Name="DescriptionTab" Spacing="16"
                                        Padding="20,16" Visibility="Collapsed">
                                <RichTextBlock x:Name="DetailDescription"
                                               Foreground="#E2E8F0" FontSize="13"
                                               TextWrapping="Wrap" LineHeight="22"/>
                                <StackPanel x:Name="MediaSection" Spacing="8" Visibility="Collapsed">
                                    <Border Height="1" Background="#2A2A3A"/>
                                    <TextBlock Text="MEDIA" Foreground="#6B7280"
                                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                                    <StackPanel x:Name="MediaContainer" Spacing="8"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Comments Tab -->
                            <StackPanel x:Name="CommentsTab" Spacing="12"
                                        Padding="20,16" Visibility="Collapsed">
                                <StackPanel x:Name="CommentsContainer" Spacing="12"/>
                                <StackPanel x:Name="LinearCommentFields" Spacing="8" Visibility="Collapsed">
                                    <Border Height="1" Background="#2A2A3A"/>
                                    <TextBlock Text="ADD COMMENT" Foreground="#6B7280"
                                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                                    <TextBox x:Name="DetailCommentBox"
                                             PlaceholderText="Write a comment..."
                                             AcceptsReturn="True" Height="80"
                                             TextWrapping="Wrap"
                                             Background="#0F0F13"
                                             Foreground="#E2E8F0"
                                             BorderBrush="#2A2A3A"
                                             CornerRadius="8"
                                             Padding="12"/>
                                </StackPanel>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>

                    <!-- Footer Actions -->
                    <Border Grid.Row="3" Padding="20,12"
                            BorderBrush="#2A2A3A" BorderThickness="0,1,0,0"
                            Background="#0F0F13">
                        <StackPanel Spacing="8">
                            <StackPanel x:Name="ManualActions" Orientation="Horizontal"
                                        Spacing="8" Visibility="Collapsed">
                                <Button Content="Save Changes" Click="SaveTaskChanges_Click"
                                        Background="#A78BFA" Foreground="White"
                                        CornerRadius="8" Padding="14,8"/>
                                <Button Content="Delete" Click="DeleteTask_Click"
                                        Background="#3F1A1A" Foreground="#F87171"
                                        CornerRadius="8" Padding="14,8"/>
                            </StackPanel>
                            <StackPanel x:Name="LinearActions" Orientation="Horizontal"
                                        Spacing="8" Visibility="Collapsed">
                                <Button Content="Post Comment" Click="PostComment_Click"
                                        Background="#A78BFA" Foreground="White"
                                        CornerRadius="8" Padding="14,8"/>
                                <Button Content="Open in Linear" Click="OpenInLinear_Click"
                                        Background="#252535" Foreground="#6B7280"
                                        CornerRadius="8" Padding="14,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>