<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DesktopApp.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F0F13">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="32" MaxWidth="600">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Settings" Foreground="#E2E8F0"
                           FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Connect your tools and manage API keys."
                           Foreground="#6B7280" FontSize="13"/>
            </StackPanel>

            <!-- Linear Section -->
            <Border Background="#1A1A24" CornerRadius="12"
                    BorderBrush="#2A2A3A" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Linear" Foreground="#E2E8F0"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Foreground="#6B7280" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Get your API key from linear.app → Settings → API → Personal API Keys"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="API Key" Foreground="#9CA3AF" FontSize="12"/>
                        <PasswordBox x:Name="LinearApiKeyBox"
                                     PlaceholderText="lin_api_..."
                                     Background="#0F0F13"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A3A"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Team ID" Foreground="#9CA3AF" FontSize="12"/>
                        <TextBox x:Name="LinearTeamIdBox"
                                 PlaceholderText="Your Linear Team ID"
                                 Background="#0F0F13"
                                 Foreground="#E2E8F0"
                                 BorderBrush="#2A2A3A"
                                 CornerRadius="8"
                                 Padding="12,10"/>
                        <TextBlock Foreground="#6B7280" FontSize="11"
                                   Text="Go to linear.app → Settings → Team → copy the ID from the URL"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Save Linear Keys"
                                Click="SaveLinear_Click"
                                Background="#252535"
                                Foreground="#A78BFA"
                                CornerRadius="8"
                                Padding="16,8"/>
                        <Button Content="Test Connection"
                                Click="TestLinear_Click"
                                Background="#252535"
                                Foreground="#6B7280"
                                CornerRadius="8"
                                Padding="16,8"/>
                        <Button Content="Disconnect"
                                Click="DisconnectLinear_Click"
                                Background="#3F1A1A"
                                Foreground="#F87171"
                                CornerRadius="8"
                                Padding="16,8"/>
                    </StackPanel>

                    <Border x:Name="LinearStatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="LinearStatusText" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Jira Section -->
            <Border Background="#1A1A24" CornerRadius="12"
                    BorderBrush="#2A2A3A" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Jira" Foreground="#E2E8F0"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Foreground="#6B7280" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Get your API token from id.atlassian.com → Security → API tokens"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Domain" Foreground="#9CA3AF" FontSize="12"/>
                        <TextBox x:Name="JiraDomainBox"
                                 PlaceholderText="your-company (from your-company.atlassian.net)"
                                 Background="#0F0F13"
                                 Foreground="#E2E8F0"
                                 BorderBrush="#2A2A3A"
                                 CornerRadius="8"
                                 Padding="12,10"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Email" Foreground="#9CA3AF" FontSize="12"/>
                        <TextBox x:Name="JiraEmailBox"
                                 PlaceholderText="your@email.com"
                                 Background="#0F0F13"
                                 Foreground="#E2E8F0"
                                 BorderBrush="#2A2A3A"
                                 CornerRadius="8"
                                 Padding="12,10"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="API Token" Foreground="#9CA3AF" FontSize="12"/>
                        <PasswordBox x:Name="JiraApiTokenBox"
                                     PlaceholderText="Your Jira API token"
                                     Background="#0F0F13"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A3A"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Project Key" Foreground="#9CA3AF" FontSize="12"/>
                        <TextBox x:Name="JiraProjectKeyBox"
                                 PlaceholderText="e.g. QA, DEV, PROJ"
                                 Background="#0F0F13"
                                 Foreground="#E2E8F0"
                                 BorderBrush="#2A2A3A"
                                 CornerRadius="8"
                                 Padding="12,10"/>
                        <TextBlock Foreground="#6B7280" FontSize="11"
                                   Text="The short key shown before issue numbers e.g. QA-123"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Save Jira Keys"
                                Click="SaveJira_Click"
                                Background="#252535"
                                Foreground="#A78BFA"
                                CornerRadius="8"
                                Padding="16,8"/>
                        <Button Content="Test Connection"
                                Click="TestJira_Click"
                                Background="#252535"
                                Foreground="#6B7280"
                                CornerRadius="8"
                                Padding="16,8"/>
                        <Button Content="Disconnect"
                                Click="DisconnectJira_Click"
                                Background="#3F1A1A"
                                Foreground="#F87171"
                                CornerRadius="8"
                                Padding="16,8"/>
                    </StackPanel>

                    <Border x:Name="JiraStatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="JiraStatusText" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>